{
  "name": "@dustinvk/wherefore-dashboard",
  "version": "0.2.0",
  "description": "Build tool that reads a wherefore/ directory and emits a static dashboard.",
  "author": "Dustin VanKrimpen",
  "license": "MIT",
  "keywords": [
    "wherefore",
    "decision-log",
    "adr",
    "architecture",
    "static-site",
    "astro",
    "dashboard"
  ],
  "homepage": "https://github.com/DustinVK/wherefore/tree/main/packages/wherefore-dashboard#readme",
  "bugs": {
    "url": "https://github.com/DustinVK/wherefore/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DustinVK/wherefore.git",
    "directory": "packages/wherefore-dashboard"
  },
  "type": "module",
  "engines": {
    "node": "^22.18.0 || >=24.0.0"
  },
  "bin": {
    "wherefore-dashboard": "bin/wherefore-dashboard.js"
  },
  "files": [
    "bin",
    "src",
    "public",
    "astro.config.mjs",
    "skills",
    "templates"
  ],
  "scripts": {
    "dev": "node bin/prepare-package.js && node bin/wherefore-dashboard.js dev",
    "build": "node bin/prepare-package.js && node bin/wherefore-dashboard.js build --src tests/fixtures/wherefore --out .test-dist",
    "test": "node bin/prepare-package.js && node --test --test-concurrency=1",
    "prepack": "node bin/prepare-package.js",
    "prepublishOnly": "node bin/prepare-package.js"
  },
  "dependencies": {
    "astro": "^7.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "jsdom": "^29.1.1"
  }
}
