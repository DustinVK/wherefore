---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { parseTopics } from '../lib/topics';

const SRC = process.env.WHEREFORE_SRC ?? '';

const allEntries    = await getCollection('log');
const activeEntries = allEntries.filter(e => e.data.status === 'active');

const vocab = parseTopics(SRC);

// Count active entries per tag
const areaCounts  = new Map<string, number>();
const topicCounts = new Map<string, number>();

for (const e of activeEntries) {
  for (const a of e.data.areas)  areaCounts.set(a,  (areaCounts.get(a)  ?? 0) + 1);
  for (const t of e.data.topics) topicCounts.set(t, (topicCounts.get(t) ?? 0) + 1);
}

// Add tags that appear in entries but not in vocab
const vocabAreaSet  = new Set(vocab.areas);
const vocabTopicSet = new Set(vocab.topics);
for (const a of areaCounts.keys())  if (!vocabAreaSet.has(a))  vocab.areas.push(a);
for (const t of topicCounts.keys()) if (!vocabTopicSet.has(t)) vocab.topics.push(t);

// Sort: count desc, then alphabetical
function sortTags(tags: string[], counts: Map<string, number>) {
  return [...tags].sort((a, b) => {
    const diff = (counts.get(b) ?? 0) - (counts.get(a) ?? 0);
    return diff !== 0 ? diff : a.localeCompare(b);
  });
}

const sortedAreas  = sortTags(vocab.areas,  areaCounts);
const sortedTopics = sortTags(vocab.topics, topicCounts);

const totalActive = activeEntries.length;
---
<Base pageTitle="Tags">
  <p class="summary-line">{totalActive} active {totalActive === 1 ? 'entry' : 'entries'} · counts exclude retired</p>

  {(sortedAreas.length === 0 && sortedTopics.length === 0) ? (
    <p class="empty">No tags yet. Add areas and topics to <code>wherefore/topics.md</code>.</p>
  ) : (
    <div class="tags-grid">
      <div class="tags-col tags-col-areas">
        <h2>Areas</h2>
        {sortedAreas.length === 0
          ? <p class="empty" style="margin-top:0">none</p>
          : sortedAreas.map(area => {
              const count = areaCounts.get(area) ?? 0;
              return (
                <a
                  href={`/log?area=${encodeURIComponent(area)}`}
                  class:list={['tagline', count === 0 && 'zero']}
                >
                  <span class="tag-nm">{area}</span>
                  <span class="tag-ct">{count}</span>
                </a>
              );
            })
        }
      </div>

      <div class="tags-col tags-col-topics">
        <h2>Topics</h2>
        {sortedTopics.length === 0
          ? <p class="empty" style="margin-top:0">none</p>
          : sortedTopics.map(topic => {
              const count = topicCounts.get(topic) ?? 0;
              return (
                <a
                  href={`/log?topic=${encodeURIComponent(topic)}`}
                  class:list={['tagline', count === 0 && 'zero']}
                >
                  <span class="tag-nm">{topic}</span>
                  <span class="tag-ct">{count}</span>
                </a>
              );
            })
        }
      </div>
    </div>
  )}
</Base>
