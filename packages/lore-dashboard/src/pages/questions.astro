---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';

const allQ = await getCollection('questions');

const withContent = await Promise.all(
  allQ.map(async q => ({ q, rendered: await render(q) }))
);

// Sort newest first by asked_date (Q-IDs are sequential so this matches ID order)
withContent.sort((a, b) => b.q.data.asked_date.localeCompare(a.q.data.asked_date));

const allAreas  = [...new Set(allQ.flatMap(q => q.data.areas))].sort();
const openCount = allQ.filter(q => q.data.status === 'open').length;
const resolvedCount = allQ.filter(q => q.data.status === 'resolved').length;
---
<Base pageTitle="Questions">
  <p class="summary-line">{openCount} open · {resolvedCount} resolved</p>

  <div class="q-filter-row">
    <button class="tab-chip active" data-tab="open" type="button">open</button>
    <button class="tab-chip" data-tab="resolved" type="button">resolved</button>
    <select id="q-area" class="filter-select" aria-label="Filter by area">
      <option value="">area: all</option>
      {allAreas.map(a => <option value={a}>{a}</option>)}
    </select>
    <input type="text" id="q-search" class="filter-search" placeholder="search…" aria-label="Search questions" />
  </div>

  <p class="no-results-msg" id="q-no-results">No matching questions.</p>

  <ul class="question-list" id="question-list">
    {withContent.map(({ q, rendered }) => {
      const { Content } = rendered;
      const hasBody = !!q.body?.trim();
      return (
        <li
          class="row"
          data-status={q.data.status}
          data-areas={q.data.areas.join(',')}
          data-question={q.data.question.toLowerCase()}
        >
          <div class="q-id-date">{q.data.id} · {q.data.asked_date}</div>
          <span class="q-text">{q.data.question}</span>
          <div class="entry-meta">
            {q.data.areas.map(a => <span class="tag tag-area">{a}</span>)}
            {q.data.status === 'open'
              ? <span class="tag tag-area">open</span>
              : <span class="tag tag-topic">resolved</span>
            }
          </div>
          {q.data.resolution && (
            <div class="q-resolution">
              {q.data.resolution_slug
                ? <><span>Resolved: </span><a href={`/log/${q.data.resolution_slug}`}>{q.data.resolution}</a></>
                : <span>Resolved: {q.data.resolution}</span>
              }
            </div>
          )}
          {hasBody && (
            <details class="q-expand">
              <summary>details</summary>
              <div class="q-body"><Content /></div>
            </details>
          )}
        </li>
      );
    })}
  </ul>
</Base>

<script is:inline>
  (function () {
    const tabBtns    = Array.from(document.querySelectorAll('.tab-chip'));
    const areaSelect = document.getElementById('q-area');
    const searchInput= document.getElementById('q-search');
    const list       = document.getElementById('question-list');
    const noResults  = document.getElementById('q-no-results');
    if (!list) return;

    const cards = Array.from(list.querySelectorAll('.row'));
    let activeTab = 'open';

    function applyFilter() {
      const area   = areaSelect   ? areaSelect.value   : '';
      const search = searchInput  ? searchInput.value.toLowerCase().trim() : '';
      let visible = 0;

      for (const card of cards) {
        const cardAreas = card.dataset.areas    ? card.dataset.areas.split(',') : [];
        const cardQ     = card.dataset.question || '';
        const matchTab    = card.dataset.status === activeTab;
        const matchArea   = !area   || cardAreas.includes(area);
        const matchSearch = !search || cardQ.includes(search);
        const show = matchTab && matchArea && matchSearch;
        card.hidden = !show;
        if (show) visible++;
      }

      if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
    }

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        activeTab = btn.dataset.tab;
        tabBtns.forEach(b => b.classList.toggle('active', b === btn));
        applyFilter();
      });
    });

    [areaSelect, searchInput].forEach(el => {
      if (el) el.addEventListener('input', applyFilter);
    });

    applyFilter();
  })();
</script>
