---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('log');
  return entries.map(e => ({ params: { slug: e.id }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allEntries = await getCollection('log');

const { status, supersededBy, supersededDate, supersedes } = entry.data;
const replacement = supersededBy ? allEntries.find(e => e.id === supersededBy) ?? null : null;
const prev        = supersedes   ? allEntries.find(e => e.id === supersedes)   ?? null : null;
---
<Base pageTitle={entry.data.title}>
  <a href="/log" class="back-link"><span class="arrow">&larr;</span> back to log</a>

  {status === 'superseded' && (
    <div class="callout">
      Superseded{supersededDate ? ` on ${supersededDate}` : ''}.
      {' '}Current decision:{' '}
      {replacement
        ? <a href={`/log/${supersededBy}`}>{replacement.data.title}</a>
        : <span>{supersededBy ?? 'unknown'}</span>
      }
    </div>
  )}

  {status === 'obsolete' && (
    <div class="callout callout-obs">
      Obsolete{supersededDate ? ` since ${supersededDate}` : ''}.
      Retired without replacement.
    </div>
  )}

  <h1 class="detail-title">{entry.data.title}</h1>

  <div class="detail-meta">
    <span class="dt">{entry.data.date}</span>
    {entry.data.areas.map(a => <span class="tag tag-area">{a}</span>)}
    {entry.data.topics.map(t => <span class="tag tag-topic">{t}</span>)}
    {entry.data.stories.map(s => <span class="tag tag-topic">{s}</span>)}
  </div>

  <div class="entry-body" id="entry-body">
    <Content />
  </div>

  {prev && (
    <p class="supersedes-note">
      Supersedes: <a href={`/log/${supersedes}`}>{prev.data.title}</a>
    </p>
  )}
  {!prev && supersedes && (
    <p class="supersedes-note">Supersedes: <code>{supersedes}</code></p>
  )}
</Base>

<script is:inline>
  // Strip the skill-written SUPERSEDED/OBSOLETE plain-text first line from
  // the body — the callout above already shows that info from frontmatter.
  const body = document.getElementById('entry-body');
  if (body) {
    const first = body.querySelector('p:first-child');
    if (first && /^(SUPERSEDED|OBSOLETE)\s/.test(first.textContent || '')) {
      first.remove();
    }
  }
</script>
